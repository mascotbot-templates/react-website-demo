        "agent": {
            "first_message": "Hey! I can help you get a moving estimate, explore career opportunities, or learn about our franchise program. What are you looking for?",
            "language": "en",
            "hinglish_mode": false,
            "dynamic_variables": {
                "dynamicVariablePlaceholders": {}
            },
            "disable_first_message_interruptions": false,
            "max_conversation_duration_message": "",
            "prompt": {
                "prompt": "You are a website assistant with THREE tools you MUST use:\n\n1. navigateTo(page) - Navigate to a page. ALWAYS call this FIRST when user mentions estimates, careers, or franchise.\n2. updateEstimateField(field, value) - Fill a form field. Call IMMEDIATELY when user provides ANY detail.\n3. submitEstimate() - Submit the form.\n\nRULES:\n- ALWAYS call tools. NEVER just talk about what you would do.\n- When user says I need an estimate, call navigateTo /estimate IMMEDIATELY.\n- When user says their name, call updateEstimateField name IMMEDIATELY.\n- When user mentions a city they are moving from, call updateEstimateField origin IMMEDIATELY.\n- When user mentions where they are going, call updateEstimateField destination IMMEDIATELY.\n- When user mentions a date, call updateEstimateField moveDate IMMEDIATELY.\n- When user mentions home size, call updateEstimateField homeSize IMMEDIATELY.\n- Call MULTIPLE tools at once if user gives multiple pieces of info.\n- NEVER repeat back what you filled. Just say Got it and ask about remaining empty fields.\n- Keep responses under 2 sentences.\n\nFIELDS: name, email, phone, origin, destination, moveDate, homeSize, specialItems\nPAGES: / (home), /estimate (form), /careers (jobs), /franchise\n\nYou may receive contextual updates about fields the user typed manually. Briefly acknowledge and move on.",
                "llm": "gpt-5.2",
                "temperature": 0.3,
                "max_tokens": -1,
                "tool_ids": [
                    "tool_3301kngxt6cnej6ab4xy6r7drc0v",
                    "tool_5201kngxteh8evnrnpw5bjqs4zk8",
                    "tool_5601kngxtmk9epntg6te0crqk8tv"
                ],
                "built_in_tools": {
                    "update_state": null,
                    "memory_entry_search": null,
                    "memory_entry_create": null,
                    "memory_entry_update": null,
                    "memory_entry_delete": null,
                    "agent_prompt_change": null,
                    "procedure_update": null,
                    "transfer_to_genesys_chat": null,
                    "search_documentation": null
                },
                "enable_parallel_tool_calls": false,
                "mcp_server_ids": [],
                "native_mcp_server_ids": [],
                "knowledge_base": [],
                "ignore_default_personality": false,
                "rag": {
                    "enabled": false,
                    "embedding_model": "e5_mistral_7b_instruct",
                    "max_vector_distance": 0.6,
                    "max_documents_length": 50000,
                    "max_retrieved_rag_chunks_count": 20
                },
                "backup_llm_config": {
                    "preference": "default"
                },
                "cascade_timeout_seconds": 8,
                "tools": [
                    {
                        "type": "client",
                        "name": "navigateTo",
                        "description": "Navigate to a page. Fire-and-forget — call and keep talking. Pages: /, /estimate, /careers, /franchise",
                        "response_timeout_secs": 1,
                        "disable_interruptions": false,
                        "force_pre_tool_speech": false,
                        "assignments": [],
                        "tool_call_sound_behavior": "auto",
                        "tool_error_handling_mode": "auto",
                        "parameters": {
                            "type": "object",
                            "required": [
                                "page"
                            ],
                            "description": "",
                            "properties": {
                                "page": {
                                    "type": "string",
                                    "description": "Page path: /, /estimate, /careers, /franchise",
                                    "is_system_provided": false,
                                    "dynamic_variable": "",
                                    "constant_value": ""
                                }
                            }
                        },
                        "expects_response": false,
                        "dynamic_variables": {
                            "dynamicVariablePlaceholders": {}
                        },
                        "execution_mode": "immediate"
                    },
                    {
                        "type": "client",
                        "name": "updateEstimateField",
                        "description": "Instantly update a form field. Fire-and-forget — call and keep talking. Call multiple times in rapid succession for different fields.",
                        "response_timeout_secs": 1,
                        "disable_interruptions": false,
                        "force_pre_tool_speech": false,
                        "assignments": [],
                        "tool_call_sound_behavior": "auto",
                        "tool_error_handling_mode": "auto",
                        "parameters": {
                            "type": "object",
                            "required": [
                                "field",
                                "value"
                            ],
                            "description": "",
                            "properties": {
                                "field": {
                                    "type": "string",
                                    "description": "Field name: name, email, phone, origin, destination, moveDate, homeSize, specialItems",
                                    "is_system_provided": false,
                                    "dynamic_variable": "",
                                    "constant_value": ""
                                },
                                "value": {
                                    "type": "string",
                                    "description": "Value to set",
                                    "is_system_provided": false,
                                    "dynamic_variable": "",
                                    "constant_value": ""
                                }
                            }
                        },
                        "expects_response": false,
                        "dynamic_variables": {
                            "dynamicVariablePlaceholders": {}
                        },
                        "execution_mode": "immediate"
                    },
                    {
                        "type": "client",
                        "name": "submitEstimate",
                        "description": "Submit the completed moving estimate form. Use this after the user has provided enough details and confirmed they want to submit. Returns a confirmation message.",
                        "response_timeout_secs": 5,
                        "disable_interruptions": false,
                        "force_pre_tool_speech": false,
                        "assignments": [],
                        "tool_call_sound_behavior": "auto",
                        "tool_error_handling_mode": "auto",
                        "parameters": {
                            "type": "object",
                            "required": [],
                            "description": "",
                            "properties": {}
                        },
                        "expects_response": true,
                        "dynamic_variables": {
                            "dynamicVariablePlaceholders": {}
                        },
                        "execution_mode": "immediate"
                    }
                ]
            }
        }
